<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A14">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00000000"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="#E60A0A14">

            <!-- Hero media container — backdrop + trailer overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.4">

                <!-- Static backdrop (always visible as fallback) -->
                <ImageView
                    android:id="@+id/backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />

                <!-- YouTube trailer WebView (hidden by default) -->
                <WebView
                    android:id="@+id/trailer_webview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />

                <!-- Mute/Unmute toggle -->
                <ImageView
                    android:id="@+id/btn_mute"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="top|end"
                    android:layout_marginEnd="12dp"
                    android:layout_marginTop="60dp"
                    android:padding="8dp"
                    android:background="@drawable/btn_circle_glass"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    android:scaleType="fitCenter"
                    android:contentDescription="Mute"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- Bottom gradient for seamless blend -->
            <View
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_gravity="bottom"
                android:background="@drawable/hero_gradient_bottom" />

            <!-- Title Logo overlay — AFTER gradient so it draws on top -->
            <ImageView
                android:id="@+id/title_logo"
                android:layout_width="120dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="65dp"
                android:scaleType="fitStart"
                android:adjustViewBounds="true"
                android:visibility="gone" />

            <!-- Meta: rating · year · type — on top of gradient -->
            <TextView
                android:id="@+id/meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="20dp"
                android:layout_marginBottom="45dp"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:letterSpacing="-0.01"
                android:shadowColor="#88000000"
                android:shadowRadius="4" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_back" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:behavior_overlapTop="60dp"
        android:overScrollMode="never"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title Text (for non-logo titles) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="0dp">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.03" />

            </LinearLayout>

            <!-- Content below title gets solid background to hide trailer on scroll -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0A0A14"
                android:paddingTop="6dp"
                android:paddingBottom="120dp">

            <!-- ════════════════════════════════════════ -->
            <!-- PLAY + MY LIST — Centered compact row   -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="6dp">

                <!-- Play Button — Compact Pill -->
                <Button
                    android:id="@+id/btn_play"
                    android:layout_width="160dp"
                    android:layout_height="44dp"
                    android:background="@drawable/btn_play_premium"
                    android:text="▶  Play"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    app:backgroundTint="@null" />

                <!-- Download button -->
                <ImageView
                    android:id="@+id/btn_download"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="14dp"
                    android:background="@drawable/btn_circle_glass"
                    android:src="@drawable/ic_download_arrow"
                    android:padding="12dp"
                    android:contentDescription="Download"
                    android:scaleType="fitCenter" />

            </LinearLayout>

            <!-- ════════════════════════════════════════ -->
            <!-- SERVER SELECTOR                          -->
            <!-- ════════════════════════════════════════ -->
            <RadioGroup
                android:id="@+id/server_radio_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/server_strip_bg"
                android:padding="3dp">

                <RadioButton
                    android:id="@+id/server_cinefy"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="Cinefy"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/server_pill_selector"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/server_zxcstream"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="ZXC"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/server_pill_selector"
                    android:layout_marginStart="2dp" />

                <RadioButton
                    android:id="@+id/server_vidrock"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="VidRock"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/server_pill_selector"
                    android:layout_marginStart="2dp" />

                <RadioButton
                    android:id="@+id/server_vidlink"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:text="VidLink"
                    android:textColor="#AAFFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/server_pill_selector"
                    android:layout_marginStart="2dp" />

            </RadioGroup>

            <!-- ════════════════════════════════════════ -->
            <!-- GENRE CHIPS                              -->
            <!-- ════════════════════════════════════════ -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp"
                android:scrollbars="none"
                android:clipToPadding="false"
                android:overScrollMode="never">
                <LinearLayout
                    android:id="@+id/genre_chips_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- ════════════════════════════════════════ -->
            <!-- SYNOPSIS                                 -->
            <!-- ════════════════════════════════════════ -->
            <TextView
                android:id="@+id/overview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="16dp"
                android:textColor="#B3B3CC"
                android:textSize="15sp"
                android:letterSpacing="-0.01"
                android:lineSpacingMultiplier="1.47" />

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:background="#0FFFFFFF" />

            <!-- ════════════════════════════════════════ -->
            <!-- EPISODES (TV Only)                       -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/season_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <!-- Header: Episodes + Season Dropdown -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Episodes"
                        android:textColor="#FFFFFF"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02" />

                    <LinearLayout
                        android:id="@+id/season_dropdown"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:background="@drawable/dropdown_pill_bg"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/season_dropdown_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Season 1"
                            android:textColor="#CCCCDD"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="▾"
                            android:textColor="#666680"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/episodes_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:background="#0FFFFFFF" />

            <!-- ════════════════════════════════════════ -->
            <!-- CAST                                     -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cast"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/cast_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false" />
            </LinearLayout>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:background="#0FFFFFFF" />

            <!-- ════════════════════════════════════════ -->
            <!-- MORE LIKE THIS                           -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/similar_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="More Like This"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:letterSpacing="-0.02" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/similar_recycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false" />
            </LinearLayout> <!-- End of similar_container -->

            </LinearLayout> <!-- End of solid background wrapper block -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
