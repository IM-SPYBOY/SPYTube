<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected / Checked state — red accent pill -->
    <item android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="#40E50914"
                        android:endColor="#25E50914"
                        android:type="linear" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <stroke android:width="1dp" android:color="#60E50914" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Default state — subtle glass -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#08FFFFFF" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
