<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle warm undertone -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#12E50914"
                android:centerColor="#08FFFFFF"
                android:endColor="#06FFFFFF"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Glass fill -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="160"
                android:startColor="#22FFFFFF"
                android:centerColor="#14FFFFFF"
                android:endColor="#0AFFFFFF"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <!-- Refined border with top highlight -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0.5dp"
                android:color="#25FFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>
